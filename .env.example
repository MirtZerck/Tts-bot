# ============================================
# CONFIGURACIÓN DEL BOT DE DISCORD TTS
# ============================================

# Token del bot de Discord (obtenlo en https://discord.com/developers/applications)
DISCORD_TOKEN=tu_token_aqui

# ID de la aplicación del bot
CLIENT_ID=tu_client_id_aqui

# ID del servidor de Discord (Guild ID) - opcional para comandos de guild
GUILD_ID=tu_guild_id_aqui

# Idioma para TTS (es = español, en = inglés, etc.)
TTS_LANGUAGE=es

# Volumen del bot (0.0 a 2.0, por defecto 1.0)
BOT_VOLUME=1.0

# Prefijo para comandos con prefijo (opcional)
BOT_PREFIX=!

# Tiempo máximo de caracteres a leer por mensaje (por defecto 200)
MAX_CHARS=200
