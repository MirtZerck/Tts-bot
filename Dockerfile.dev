# ============================================================
# Dockerfile.dev — Imagen de desarrollo con hot-reload
# ============================================================
FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache \
    ffmpeg \
    python3 \
    make \
    g++ \
    && rm -rf /var/cache/apk/*

COPY package.json tsconfig.json ./

RUN npm install --ignore-scripts

CMD ["npx", "ts-node", "--transpile-only", "src/index.ts"]
